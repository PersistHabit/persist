{
	"name": "persist",
	"version": "1.1.0",
	"private": true,
	"type": "module",
	"license": "UNLICENSED",
	"packageManager": "pnpm@10.30.3",
	"engines": {
		"node": "24.16.0"
	},
	"scripts": {
		"start": "node bin/server.js",
		"build": "node ace build",
		"dev": "node ace serve --hmr",
		"test": "NODE_ENV=test node ace test",
		"lint": "biome check . && eslint .",
		"lint:fix": "biome check --write .",
		"format": "biome format .",
		"format:fix": "biome format --write .",
		"typecheck": "tsc --noEmit"
	},
	"imports": {
		"#generated/*": "./.adonisjs/server/*.js",
		"#transformers/*": "./app/transformers/*.js",
		"#controllers/*": "./app/controllers/*.js",
		"#exceptions/*": "./app/exceptions/*.js",
		"#models/*": "./app/models/*.js",
		"#mails/*": "./app/mails/*.js",
		"#services/*": "./app/services/*.js",
		"#listeners/*": "./app/listeners/*.js",
		"#events/*": "./app/events/*.js",
		"#middleware/*": "./app/middleware/*.js",
		"#validators/*": "./app/validators/*.js",
		"#providers/*": "./providers/*.js",
		"#policies/*": "./app/policies/*.js",
		"#abilities/*": "./app/abilities/*.js",
		"#database/*": "./database/*.js",
		"#tests/*": "./tests/*.js",
		"#start/*": "./start/*.js",
		"#config/*": "./config/*.js",
		"#types/*": "./types/*.js"
	},
	"devDependencies": {
		"@adonisjs/assembler": "^8.0.0",
		"@adonisjs/eslint-config": "^3.0.0",
		"@adonisjs/tsconfig": "^2.0.0",
		"@biomejs/biome": "2.3.14",
		"@japa/api-client": "^3.2.1",
		"@japa/assert": "^4.0.1",
		"@japa/plugin-adonisjs": "^5.1.0",
		"@japa/runner": "^4.2.0",
		"@poppinss/ts-exec": "^1.4.4",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.1.18",
		"@types/luxon": "^3.7.1",
		"@types/node": "^22.15.18",
		"@types/react": "^19.2.11",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^5.1.3",
		"argon2": "^0.44.0",
		"clsx": "^2.1.1",
		"eslint": "^9.26.0",
		"eslint-plugin-react": "^7.37.5",
		"eslint-plugin-react-hooks": "^7.0.1",
		"framer-motion": "^12.33.0",
		"hot-hook": "^0.4.0",
		"pino-pretty": "^13.0.0",
		"tailwindcss": "^4.1.18",
		"typescript": "~5.8.3",
		"vite": "^7.3.1",
		"youch": "^4.1.0",
		"zod": "^4.3.6"
	},
	"dependencies": {
		"@adonisjs/auth": "^10.0.0",
		"@adonisjs/cache": "^1.3.1",
		"@adonisjs/core": "^7.0.0",
		"@adonisjs/cors": "^3.0.0",
		"@adonisjs/inertia": "^4.0.0",
		"@adonisjs/limiter": "^3.0.0",
		"@adonisjs/lucid": "^22.0.0",
		"@adonisjs/redis": "^10.0.0",
		"@adonisjs/session": "^8.0.0",
		"@adonisjs/shield": "^9.0.0",
		"@adonisjs/static": "^2.0.0",
		"@adonisjs/vite": "^5.1.0",
		"@inertiajs/react": "^2.3.13",
		"@tuyau/client": "^0.2.10",
		"@tuyau/core": "^1.0.0",
		"@vinejs/vine": "^4.3.0",
		"edge.js": "^6.5.0",
		"lucide-react": "^0.563.0",
		"luxon": "^3.7.2",
		"pg": "^8.18.0",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"reflect-metadata": "^0.2.2"
	},
	"hotHook": {
		"boundaries": [
			"./app/controllers/**/*.ts",
			"./app/middleware/*.ts"
		]
	}
}
