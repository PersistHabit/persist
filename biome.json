{
	"files": {
		"includes": [
			"**",
			"!.adonisjs",
			"!**/.adonisjs",
			"!build",
			"!database/schema.ts"
		]
	},
	"linter": {
		"rules": {
			"suspicious": {
				"noUnknownAtRules": "off"
			},
			"correctness": {
				"useHookAtTopLevel": "off"
			}
		}
	},
	"css": {
		"parser": {
			"tailwindDirectives": true
		}
	}
}
